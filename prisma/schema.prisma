generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobSearchStage {
  EXPLORING
  PREPARING
  APPLYING
  INTERVIEWING
  OFFER_STAGE
}

enum ContentType {
  DASHBOARD
  ROLE_RECOMMENDATION
  RESUME_ANALYSIS
  OUTREACH
  APPLICATION_PLAN
  TIMELINE
  JOB_MATCH
}

enum ResumeStatus {
  ACTIVE
  ARCHIVED
}

model User {
  id                String                   @id @default(cuid())
  name              String?
  email             String                   @unique
  emailVerified     DateTime?
  image             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  profile           Profile?
  resumes           Resume[]
  resumeAnalyses    ResumeAnalysis[]
  dashboardInsights DashboardInsight[]
  roleRecommendations RoleRecommendation[]
  outreachTemplateSets OutreachTemplateSet[]
  applicationPlans  ApplicationPlan[]
  timelinePlans     TimelinePlan[]
  savedJobs         SavedJob[]
  generatedHistory  GeneratedContentHistory[]
  accounts          Account[]
  sessions          Session[]
}

model Profile {
  id                       String         @id @default(cuid())
  userId                   String         @unique
  fullName                 String
  major                    String
  industryInterest         String
  companyTypes             String[]
  preferredLocations       String[]
  yearsExperience          String
  graduationDate           DateTime
  jobSearchStage           JobSearchStage
  earliestStartDate        DateTime
  otherMajor               String?
  otherIndustryInterest    String?
  otherCompanyType         String?
  otherPreferredLocation   String?
  bio                      String?
  targetRoleFocus          String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
  user                     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resume {
  id              String          @id @default(cuid())
  userId          String
  fileName        String
  mimeType        String
  size            Int
  content         Bytes
  extractedText   String
  status          ResumeStatus    @default(ACTIVE)
  uploadedAt      DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses        ResumeAnalysis[]
}

model ResumeAnalysis {
  id                  String   @id @default(cuid())
  userId              String
  resumeId            String?
  overallAssessment   String
  strengths           Json
  weaknesses          Json
  atsConcerns         Json
  framingSuggestions  Json
  bulletRewriteIdeas  Json
  tailoredRecommendations Json
  createdAt           DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume              Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
}

model DashboardInsight {
  id                  String   @id @default(cuid())
  userId              String
  headline            String
  bestFitDirections   Json
  resumePriorities    Json
  outreachPriorities  Json
  applicationPriorities Json
  timingAdvice        Json
  nextActions         Json
  generatedAt         DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoleRecommendation {
  id                    String   @id @default(cuid())
  userId                String
  summary               String
  roleCategories        Json
  keywords              Json
  competitiveness       Json
  generatedAt           DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OutreachTemplateSet {
  id              String   @id @default(cuid())
  userId          String
  tone            String
  networkingEmail Json
  linkedInMessage Json
  interviewRequest Json
  followUpNote    Json
  thankYouEmail   Json
  tips            Json
  generatedAt     DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApplicationPlan {
  id              String   @id @default(cuid())
  userId          String
  summary         String
  weeklyTarget    String
  realisticRoles  Json
  prioritization  Json
  followUpCadence Json
  tailoringChecklist Json
  generatedAt     DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TimelinePlan {
  id              String   @id @default(cuid())
  userId          String
  summary         String
  timelineMode    String
  milestones      Json
  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedJob {
  id              String   @id @default(cuid())
  userId          String
  providerJobId   String
  source          String
  title           String
  company         String
  location        String
  datePosted      DateTime?
  employmentType  String?
  shortDescription String
  applicationUrl  String
  roleCategory    String?
  matchRationale  String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerJobId, source])
}

model JobCache {
  id              String   @id @default(cuid())
  cacheKey        String   @unique
  query           String
  location        String?
  experienceLevel String?
  roleCategory    String?
  remoteMode      String?
  source          String
  jobs            Json
  fetchedAt       DateTime @default(now())
  expiresAt       DateTime
}

model GeneratedContentHistory {
  id              String      @id @default(cuid())
  userId          String
  contentType     ContentType
  title           String
  payload         Json
  createdAt       DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
